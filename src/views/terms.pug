    meta(name='description', content='Terms and Conditions for electerm website and software.')
    meta(name='keywords', content=keywords)
    meta(property='og:title' content='electerm - Terms & Conditions')
    meta(property='og:description' content='Terms and Conditions for electerm website and software.')
    meta(name='twitter:title' content='electerm - Terms & Conditions')
    meta(name='twitter:description' content='Terms and Conditions for electerm website and software.')
    include ./parts/react-header
    script(type='application/ld+json').
      {
        "@context": "https://schema.org",
        "@type": "BreadcrumbList",
        "itemListElement": [
          { "@type": "ListItem", "position": 1, "name": "Home", "item": "#{host}" },
          { "@type": "ListItem", "position": 2, "name": "Terms", "item": "#{host}/terms/" }
        ]
      }
