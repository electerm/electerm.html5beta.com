doctype html
html(lang=langCode)
  head
    title #{siteName} - #{lang.lang.sponsorTitle}
    meta(name='description', content=desc)
    meta(name='keywords', content=keywords)
    meta(property='og:title' content='electerm - Support Open Source Development')
    meta(property='og:description' content='Sponsor electerm terminal client development')
    meta(name='twitter:title' content='electerm - Support Open Source Development')
    meta(name='twitter:description' content='Sponsor electerm terminal client development')
    include ./parts/react-header
    style.
      .sponsor-hero {
        background: var(--color-bg-alt);
        padding: 48px 0;
        text-align: center;
      }
      .sponsor-hero h1 {
        font-size: 2rem;
        font-weight: 700;
        margin-bottom: 8px;
      }
      .sponsor-hero p {
        color: var(--color-text-secondary);
        font-size: 1.05rem;
        max-width: 500px;
        margin: 0 auto;
      }
      .sponsor-section {
        padding: 60px 0 80px;
        background: var(--color-bg);
      }
      .sponsor-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 20px;
        max-width: 720px;
        margin: 0 auto;
      }
      @media (min-width: 480px) {
        .sponsor-grid { grid-template-columns: repeat(2, 1fr); }
      }
      .sponsor-card {
        display: flex;
        flex-direction: column;
        align-items: center;
        padding: 32px 24px;
        background: var(--color-bg);
        border: 1px solid var(--color-border);
        border-radius: var(--radius-lg);
        text-decoration: none;
        color: inherit;
        transition: all 0.25s;
        text-align: center;
      }
      .sponsor-card:hover {
        border-color: var(--color-primary);
        box-shadow: var(--shadow-md);
        transform: translateY(-2px);
      }
      .sponsor-card.featured {
        grid-column: 1 / -1;
        flex-direction: row;
        gap: 32px;
        padding: 36px 32px;
        background: linear-gradient(135deg, var(--color-bg-alt), var(--color-bg));
        border-color: var(--color-primary);
        border-width: 2px;
      }
      @media (max-width: 479px) {
        .sponsor-card.featured {
          flex-direction: column;
          gap: 20px;
          padding: 32px 24px;
        }
      }
      .sponsor-card.featured .sponsor-qr {
        flex-shrink: 0;
        width: 160px;
        height: 160px;
        border-radius: var(--radius-md);
        overflow: hidden;
        box-shadow: var(--shadow-md);
      }
      .sponsor-card.featured .sponsor-qr img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
      }
      .sponsor-card.featured .sponsor-info {
        text-align: left;
      }
      @media (max-width: 479px) {
        .sponsor-card.featured .sponsor-info {
          text-align: center;
        }
      }
      .sponsor-card.featured .sponsor-badge {
        display: inline-block;
        font-size: 0.7rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        padding: 3px 10px;
        border-radius: 999px;
        background: var(--color-primary);
        color: #fff;
        margin-bottom: 12px;
      }
      .sponsor-card.featured h3 {
        font-size: 1.2rem;
        margin-bottom: 8px;
      }
      .sponsor-card.featured p {
        font-size: 0.9rem;
        line-height: 1.5;
      }
      .sponsor-icon {
        width: 48px;
        height: 48px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: var(--radius-md);
        background: var(--color-primary-light);
        color: var(--color-primary);
        font-size: 1.4rem;
        margin-bottom: 16px;
      }
      .sponsor-card h3 {
        font-size: 1.05rem;
        font-weight: 600;
        margin-bottom: 8px;
        color: var(--color-text);
      }
      .sponsor-card p {
        font-size: 0.85rem;
        color: var(--color-text-secondary);
      }
  body
    include ./parts/header
    section.sponsor-hero
      .container
        h1 #{lang.lang.sponsorTitle}
        p #{lang.lang.sponsorSubtitle}
    section.sponsor-section
      .container
        .sponsor-grid
          .sponsor-card.featured
            .sponsor-qr
              img(src='https://electerm.org/electerm-wechat-donate.png' alt='WeChat Donate QR Code', loading='lazy')
            .sponsor-info
              h3 #{lang.lang.sponsorWechatDonate}
              p #{lang.lang.sponsorWechatDonateDesc}
          a.sponsor-card(href='https://github.com/sponsors/electerm', target='_blank', rel='noreferrer')
            .sponsor-icon ❤️
            h3 #{lang.lang.sponsorGithubSponsors}
            p #{lang.lang.sponsorGithubSponsorsDesc}
          a.sponsor-card(href='https://ko-fi.com/zhaoxudong', target='_blank', rel='noreferrer')
            .sponsor-icon ☕
            h3 #{lang.lang.sponsorKoFi}
            p #{lang.lang.sponsorKoFiDesc}
          a.sponsor-card(href='https://opencollective.com/electerm', target='_blank', rel='noreferrer')
            .sponsor-icon 🌍
            h3 #{lang.lang.sponsorOpenCollective}
            p #{lang.lang.sponsorOpenCollectiveDesc}
    include ./parts/sponsors
    include ./parts/footer
    include ./parts/react-footer
