section.deb-hero
  .container
    img.deb-hero-logo(src=host + '/electerm.png', alt='electerm')
    h1 #{lang.lang.debTitle}
    p.deb-hero-tagline #{lang.lang.debSubtitle}

section.deb-features
  .container
    .section-header
      h2 #{lang.lang.debWhyUse}
    .features-grid
      .feature-card
        .feature-icon 🔒
        h3 #{lang.lang.debSecureVerifiedTitle}
        p #{lang.lang.debSecureVerifiedDesc}
      .feature-card
        .feature-icon ⚡
        h3 #{lang.lang.debAutoUpdatesTitle}
        p #{lang.lang.debAutoUpdatesDesc}
      .feature-card
        .feature-icon 🏗️
        h3 #{lang.lang.debX86SupportTitle}
        p #{lang.lang.debX86SupportDesc}

section.deb-steps
  .container
    .section-header
      h2 #{lang.lang.debInstallation}
      p #{lang.lang.debInstallationSubtitle}

    .steps-grid
      .step-card
        .step-number 1
        .step-content
          h3 #{lang.lang.debAddRepository}
          p #{lang.lang.debAddRepositoryDesc}

          .code-block
            button.copy-button(onclick="copyToClipboard(this)") #{lang.lang.debCopy}
            pre.
              # Add the GPG key
              curl -fsSL https://electerm-repos.html5beta.com/deb/public.key | sudo gpg --dearmor -o /usr/share/keyrings/electerm.gpg

              # Add the repository
              echo "deb [arch=amd64 signed-by=/usr/share/keyrings/electerm.gpg] https://electerm-repos.html5beta.com/deb stable main" | sudo tee /etc/apt/sources.list.d/electerm.list

      .step-card
        .step-number 2
        .step-content
          h3 #{lang.lang.debUpdateInstall}
          p #{lang.lang.debUpdateInstallDesc}

          .code-block
            button.copy-button(onclick="copyToClipboard(this)") #{lang.lang.debCopy}
            pre.
              # Update package list
              sudo apt update

              # Install Electerm
              sudo apt install electerm

    .deb-success
      .deb-success-icon ✅
      .deb-success-text
        h4 #{lang.lang.debThatsIt}
        p #{lang.lang.debThatsItDesc}

section.deb-info
  .container
    .section-header
      h2 #{lang.lang.debRepositoryDetails}

    .info-grid
      .info-card
        .info-card-label #{lang.lang.debRepositoryUrl}
        .info-card-value https://electerm-repos.html5beta.com/deb
      .info-card
        .info-card-label #{lang.lang.debDistribution}
        .info-card-value stable
      .info-card
        .info-card-label #{lang.lang.debComponent}
        .info-card-value main
      .info-card
        .info-card-label #{lang.lang.debArchitecture}
        .info-card-value amd64
      .info-card
        .info-card-label #{lang.lang.debGpgKey}
        .info-card-value
          a(href="public.key") #{lang.lang.debDownloadPublicKey}

section.deb-security
  .container
    .section-header
      h2 #{lang.lang.debSecurityFeatures}

    .security-grid
      .security-card
        .security-icon 🔐
        h4 #{lang.lang.debGpgSignedTitle}
        p #{lang.lang.debGpgSignedDesc}
      .security-card
        .security-icon 🌐
        h4 #{lang.lang.debHttpsTransportTitle}
        p #{lang.lang.debHttpsTransportDesc}
      .security-card
        .security-icon 🤖
        h4 #{lang.lang.debAutomatedUpdatesTitle}
        p #{lang.lang.debAutomatedUpdatesDesc}
      .security-card
        .security-icon ✓
        h4 #{lang.lang.debVerifiedPackagesTitle}
        p #{lang.lang.debVerifiedPackagesDesc}
