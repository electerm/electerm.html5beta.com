section.hero
  #hero-anim
  .container
    img.hero-logo(src=host + '/electerm.png', alt='electerm', fetchpriority='high')
    h1.hero-title electerm
    p.hero-tagline #{desc}
    .hero-version
      span.dot
      span Version #{version}
      span(style='opacity:0.6;margin-left:4px') #{assets.windows.x64.releaseDate || assets.windows.arm64.releaseDate}
    .hero-cta
      a.hero-btn.hero-btn-primary(href='#downloads')
        | Download #{version}
      a.hero-btn.hero-btn-secondary(href='#demo')
        | #{lang.lang.heroTryDemo}
      a.hero-btn.hero-btn-secondary(href='https://github.com/electerm/electerm', target='_blank', rel='noreferrer')
        | #{lang.lang.heroViewOnGithub}
