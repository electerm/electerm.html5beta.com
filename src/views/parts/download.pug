section.downloads#downloads
  .container
    .section-header
      h2 Download
      p Free and open source — choose your platform

    //- Auto-detect OS script
    script.
      function detectOS() {
        var p = navigator.platform.toLowerCase();
        var u = navigator.userAgent.toLowerCase();
        if (p.includes('mac') || u.includes('mac')) return 'mac';
        if (p.includes('win') || u.includes('windows')) return 'windows';
        if (p.includes('linux') || u.includes('linux')) return 'linux';
        return 'windows';
      }
      function switchTab(os) {
        document.querySelectorAll('.download-tab-btn').forEach(function(b){
          b.classList.toggle('active', b.getAttribute('data-tab')===os);
        });
        document.querySelectorAll('.download-panel').forEach(function(p){
          p.classList.toggle('active', p.getAttribute('data-tab')===os);
        });
      }
      function switchArch(btn, arch) {
        var container = btn.closest('.arch-bar').parentElement;
        container.querySelectorAll('.arch-btn').forEach(function(b){
          b.classList.toggle('active', b.getAttribute('data-arch')===arch);
        });
        container.querySelectorAll('.arch-panel').forEach(function(p){
          p.classList.toggle('active', p.getAttribute('data-arch')===arch);
        });
      }
      document.addEventListener('DOMContentLoaded', function(){
        switchTab(detectOS());
        document.querySelectorAll('.download-tab-btn').forEach(function(b){
          b.addEventListener('click', function(){ switchTab(this.getAttribute('data-tab')); });
        });
        document.querySelectorAll('.arch-bar').forEach(function(bar){
          bar.querySelectorAll('.arch-btn').forEach(function(b){
            b.addEventListener('click', function(){ switchArch(this, this.getAttribute('data-arch')); });
          });
        });
      });

    mixin dlLinks(obj)
      .download-card-links
        a.download-card-link.primary(href=obj.browser_download_url) GitHub
        a.download-card-link(href=obj.sourceforgeUrl) SourceForge
        a.download-card-link(href='https://electerm-mirror.html5beta.com/' + obj.browser_download_url) gh-proxy
        a.download-card-link(href='https://r2.electerm.org/r/' + obj.browser_download_url.split('/').pop()) R2

    mixin dlCard(obj)
      .download-card
        .download-card-info
          .download-card-name #{obj.name}
          - if (obj.desc)
            .download-card-desc #{obj.desc}
        +dlLinks(obj)

    .download-tabs-bar
      button.download-tab-btn.active(data-tab='windows') Windows
      button.download-tab-btn(data-tab='mac') macOS
      button.download-tab-btn(data-tab='linux') Linux

    //- Windows
    .download-panel.active(data-tab='windows')
      .arch-bar
        button.arch-btn.active(data-arch='x64') x64
        button.arch-btn(data-arch='arm64') ARM64
        - if (assets.windows.win7 && assets.windows.win7.items.length > 0)
          button.arch-btn(data-arch='win7') Windows 7
      .arch-panel.active(data-arch='x64')
        .download-grid
          each obj in assets.windows.x64.items
            +dlCard(obj)
      .arch-panel(data-arch='arm64')
        .download-grid
          each obj in assets.windows.arm64.items
            +dlCard(obj)
      - if (assets.windows.win7 && assets.windows.win7.items.length > 0)
        .arch-panel(data-arch='win7')
          .download-grid
            each obj in assets.windows.win7.items
              +dlCard(obj)

    //- macOS
    .download-panel(data-tab='mac')
      .download-grid
        each obj in assets.mac.items
          +dlCard(obj)

    //- Linux
    .download-panel(data-tab='linux')
      .arch-bar
        button.arch-btn.active(data-arch='x86_64') x86_64
        button.arch-btn(data-arch='arm64') ARM64
        button.arch-btn(data-arch='armv7') ARMv7
        button.arch-btn(data-arch='loong64') LoongArch64
      .arch-panel.active(data-arch='x86_64')
        .download-grid
          each obj in assets.linux.x86_64.items
            +dlCard(obj)
      .arch-panel(data-arch='arm64')
        .download-grid
          each obj in assets.linux.arm64.items
            +dlCard(obj)
      .arch-panel(data-arch='armv7')
        .download-grid
          each obj in assets.linux.armv7.items
            +dlCard(obj)
      .arch-panel(data-arch='loong64')
        .download-grid
          each obj in assets.linux.loong64.items
            +dlCard(obj)

    .download-more
      a(href='https://github.com/electerm/electerm/releases', target='_blank', rel='noreferrer')
        | View all releases on GitHub →
