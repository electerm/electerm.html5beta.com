doctype html
html(lang=langCode)
  head
    title Electerm Debian Repository
    meta(name='description', content='Official Debian repository for Electerm terminal application')
    meta(name='keywords', content='electerm,debian,repository,apt,setup,install,linux,terminal,ssh')
    meta(property='og:title' content='electerm - Debian Repository Setup')
    meta(property='og:description' content='Official Debian repository for Electerm terminal application')
    meta(name='twitter:title' content='electerm - Debian Repository Setup')
    meta(name='twitter:description' content='Official Debian repository for Electerm terminal application')
    include ./parts/react-header
  body
    include ./parts/header
    include ./parts/deb
    include ./parts/download
    include ./parts/community
    include ./parts/sponsors
    #container
    include ./parts/footer
    include ./parts/react-footer
    script.
      function copyToClipboard(button) {
          const codeBlock = button.parentElement;
          const preElement = codeBlock.querySelector('pre');

          if (!preElement) {
              console.error('No pre element found');
              return;
          }

          const textToCopy = preElement.textContent || preElement.innerText;

          if (navigator.clipboard && window.isSecureContext) {
              navigator.clipboard.writeText(textToCopy).then(() => {
                  showCopySuccess(button);
              }).catch(err => {
                  console.error('Failed to copy using Clipboard API:', err);
                  fallbackCopyToClipboard(textToCopy, button);
              });
          } else {
              fallbackCopyToClipboard(textToCopy, button);
          }
      }

      function fallbackCopyToClipboard(text, button) {
          const textArea = document.createElement('textarea');
          textArea.value = text;
          textArea.style.position = 'fixed';
          textArea.style.left = '-999999px';
          textArea.style.top = '-999999px';
          document.body.appendChild(textArea);
          textArea.focus();
          textArea.select();

          try {
              const successful = document.execCommand('copy');
              if (successful) {
                  showCopySuccess(button);
              } else {
                  showCopyError(button);
              }
          } catch (err) {
              console.error('Fallback copy failed:', err);
              showCopyError(button);
          }

          document.body.removeChild(textArea);
      }

      function showCopySuccess(button) {
          const originalText = button.textContent;
          button.textContent = 'Copied!';
          button.classList.add('copied');

          setTimeout(() => {
              button.textContent = originalText;
              button.classList.remove('copied');
          }, 2000);
      }

      function showCopyError(button) {
          const originalText = button.textContent;
          button.textContent = 'Error';
          button.style.background = '#f8d7da';
          button.style.color = '#721c24';
          button.style.borderColor = '#f5c6cb';

          setTimeout(() => {
              button.textContent = originalText;
              button.style.background = '';
              button.style.color = '';
              button.style.borderColor = '';
          }, 2000);
      }
