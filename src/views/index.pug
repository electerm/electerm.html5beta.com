doctype html
html(lang=langCode)
  head
    title= 'electerm - ' + (lang.lang.siteTitleShort || 'Terminal/SSH/SFTP Client')
    meta(name='description', content=desc)
    meta(name='keywords', content=keywords)
    meta(property='og:title' content='electerm - ' + (lang.lang.siteTitleShort || 'Terminal/SSH/SFTP Client'))
    meta(property='og:description' content=desc)
    meta(name='twitter:title' content='electerm - ' + (lang.lang.siteTitleShort || 'Terminal/SSH/SFTP Client'))
    meta(name='twitter:description' content=desc)
    include ./parts/react-header
    script(type='application/ld+json').
      {
        "@context": "https://schema.org",
        "@type": "WebSite",
        "name": "electerm",
        "url": "#{host}",
        "description": "Free and open-sourced terminal/ssh/sftp/telnet/serialport/RDP/VNC/Spice/ftp client (linux, mac, win)",
        "inLanguage": "#{langCode}"
      }
    script(type='application/ld+json').
      {
        "@context": "https://schema.org",
        "@type": "SoftwareApplication",
        "name": "electerm",
        "description": "Free and open-sourced terminal/ssh/sftp/telnet/serialport/RDP/VNC/Spice/ftp client (linux, mac, win)",
        "url": "#{host}",
        "applicationCategory": "DeveloperApplication",
        "operatingSystem": "Windows, macOS, Linux",
        "softwareVersion": "#{version}",
        "datePublished": "#{releaseDate}",
        "image": "#{host}/android-chrome-512x512.png",
        "downloadUrl": "https://github.com/electerm/electerm/releases",
        "offers": {
          "@type": "Offer",
          "price": "0",
          "priceCurrency": "USD"
        },
        "author": {
          "@type": "Person",
          "name": "ZHAO Xudong",
          "url": "https://html5beta.com",
          "jobTitle": "Full-stack Developer",
          "sameAs": [
            "https://github.com/zxdong262",
            "https://html5beta.com/page/timeline.html"
          ]
        },
        "softwareHelp": {
          "@type": "CreativeWork",
          "url": "https://github.com/electerm/electerm/wiki"
        },
        "featureList": [
          "SSH client",
          "Telnet client",
          "Serial port connection",
          "SFTP file transfer",
          "Multi-tab terminal",
          "Theme customization"
        ]
      }
    script(type='application/ld+json').
      {
        "@context": "https://schema.org",
        "@type": "Organization",
        "name": "electerm",
        "url": "#{host}",
        "logo": "#{host}/electerm.png",
        "sameAs": [
          "https://github.com/electerm/electerm",
          "https://snapcraft.io/electerm",
          "https://html5beta.com",
          "https://www.microsoft.com/store/apps/9NCN7272GTFF",
          "https://cloud.electerm.org"
        ]
      }
  body
    include ./parts/header
    main
      include ./parts/hero
      include ./parts/features
      include ./parts/demo
      include ./parts/download
      include ./parts/links
      include ./parts/changelog
      include ./parts/community
      include ./parts/sponsors
      include ./parts/star-history
      include ./parts/faq-home
      include ./parts/author
      #container
    include ./parts/footer
    include ./parts/react-footer
