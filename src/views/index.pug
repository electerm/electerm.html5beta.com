doctype html
html(lang=langCode)
  head
    title #{siteName} - Free and Open-Sourced Terminal/SSH/SFTP/Telnet/Serialport/VNC/RDP/Spice Client
    meta(name='description', content=desc)
    meta(name='keywords', content=keywords)
    meta(property='og:title' content='electerm - Free and Open-Sourced Terminal/SSH/SFTP/Telnet/Serialport/VNC/RDP/Spice Client')
    meta(property='og:description' content=desc)
    meta(name='twitter:title' content='electerm - Free and Open-Sourced Terminal/SSH/SFTP/Telnet/Serialport/VNC/RDP/Spice Client')
    meta(name='twitter:description' content=desc)
    include ./parts/react-header
    script(type='application/ld+json').
      {
        "@context": "https://schema.org",
        "@type": "SoftwareApplication",
        "name": "electerm",
        "description": "Free and open-sourced terminal/ssh/sftp/telnet/serialport/RDP/VNC/Spice/ftp client (linux, mac, win)",
        "url": "https://electerm.org",
        "applicationCategory": "DeveloperApplication",
        "operatingSystem": "Windows, macOS, Linux",
        "offers": {
          "@type": "Offer",
          "price": "0",
          "priceCurrency": "USD"
        },
        "author": {
          "@type": "Person",
          "name": "ZHAO Xudong",
          "url": "http://html5beta.com"
        },
        "softwareHelp": {
          "@type": "CreativeWork",
          "url": "https://github.com/electerm/electerm/wiki"
        },
        "featureList": [
          "SSH client",
          "Telnet client",
          "Serial port connection",
          "SFTP file transfer",
          "Multi-tab terminal",
          "Theme customization"
        ]
      }
  body
    include ./parts/header
    include ./parts/hero
    include ./parts/features
    include ./parts/demo
    include ./parts/download
    include ./parts/links
    include ./parts/changelog
    include ./parts/community
    include ./parts/sponsors
    include ./parts/star-history
    include ./parts/faq-home
    include ./parts/author
    #container
    include ./parts/footer
    include ./parts/react-footer
