/* ===== CSS Variables & Reset ===== */
:root
  --color-primary: #2563eb
  --color-primary-dark: #1d4ed8
  --color-primary-light: #dbeafe
  --color-accent: #06b6d4
  --color-bg: #ffffff
  --color-bg-alt: #f8fafc
  --color-text: #0f172a
  --color-text-secondary: #64748b
  --color-text-inverse: #ffffff
  --color-border: #e2e8f0
  --color-border-light: #f1f5f9
  --color-success: #10b981
  --color-warning: #f59e0b
  --radius-sm: 6px
  --radius-md: 10px
  --radius-lg: 16px
  --radius-xl: 24px
  --shadow-sm: 0 1px 2px rgba(0,0,0,0.05)
  --shadow-md: 0 4px 6px -1px rgba(0,0,0,0.07), 0 2px 4px -2px rgba(0,0,0,0.05)
  --shadow-lg: 0 10px 15px -3px rgba(0,0,0,0.08), 0 4px 6px -4px rgba(0,0,0,0.04)
  --shadow-xl: 0 20px 25px -5px rgba(0,0,0,0.08), 0 8px 10px -6px rgba(0,0,0,0.04)
  --font-sans: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif
  --font-mono: 'SF Mono', 'Fira Code', 'Fira Mono', 'Roboto Mono', monospace
  --max-width: 1200px
  --header-height: 64px

*, *::before, *::after
  box-sizing border-box
  margin 0
  padding 0

html
  scroll-behavior smooth
  -webkit-text-size-adjust 100%
  overflow-x hidden

body
  font-family var(--font-sans)
  color var(--color-text)
  background var(--color-bg)
  line-height 1.6
  -webkit-font-smoothing antialiased
  -moz-osx-font-smoothing grayscale
  overflow-x hidden

img
  max-width 100%
  height auto

a
  color var(--color-primary)
  text-decoration none
  transition color 0.2s

a:hover
  color var(--color-primary-dark)

/* ===== Utility ===== */
.container
  width 100%
  max-width var(--max-width)
  margin 0 auto
  padding 0 20px

@media (min-width: 768px)
  .container
    padding 0 32px

.sr-only
  position absolute
  width 1px
  height 1px
  padding 0
  margin -1px
  overflow hidden
  clip rect(0,0,0,0)
  white-space nowrap
  border 0

/* ===== Header ===== */
.site-header
  position sticky
  top 0
  z-index 100
  background rgba(255,255,255,0.92)
  backdrop-filter blur(12px)
  -webkit-backdrop-filter blur(12px)
  border-bottom 1px solid var(--color-border)
  height var(--header-height)

.header-inner
  display flex
  align-items center
  justify-content space-between
  height var(--header-height)

.header-logo
  display flex
  align-items center
  gap 10px
  font-weight 700
  font-size 1.15rem
  color var(--color-text)
  text-decoration none

.header-logo:hover
  color var(--color-text)

.header-logo img
  height 32px
  width auto

.header-nav
  display none
  align-items center
  gap 8px

@media (min-width: 768px)
  .header-nav
    display flex

.header-nav a
  padding 8px 14px
  border-radius var(--radius-sm)
  color var(--color-text-secondary)
  font-size 0.9rem
  font-weight 500
  transition all 0.15s

.header-nav a:hover
  color var(--color-text)
  background var(--color-bg-alt)

.header-actions
  display flex
  align-items center
  gap 8px

.lang-dropdown
  position relative

.lang-toggle
  display flex
  align-items center
  gap 6px
  padding 6px 10px
  border 1px solid var(--color-border)
  border-radius var(--radius-sm)
  background var(--color-bg)
  cursor pointer
  font-size 0.9rem
  color var(--color-text-secondary)
  transition all 0.15s

.lang-toggle:hover
  border-color var(--color-primary)
  color var(--color-primary)

.lang-toggle .flag
  font-size 1.1rem

.lang-toggle .arrow
  font-size 0.65rem
  transition transform 0.2s

.lang-dropdown.open .lang-toggle .arrow
  transform rotate(180deg)

.lang-menu
  display none
  position absolute
  top calc(100% + 6px)
  right 0
  background var(--color-bg)
  border 1px solid var(--color-border)
  border-radius var(--radius-md)
  box-shadow var(--shadow-lg)
  min-width 180px
  max-height 400px
  overflow-y auto
  z-index 200
  padding 6px

.lang-dropdown.open .lang-menu
  display block

.lang-menu a
  display flex
  align-items center
  gap 10px
  padding 8px 12px
  border-radius var(--radius-sm)
  color var(--color-text)
  font-size 0.85rem
  white-space nowrap

.lang-menu a:hover
  background var(--color-bg-alt)
  color var(--color-primary)

.lang-menu a .flag
  font-size 1rem
  width 20px
  text-align center

.mobile-menu-btn
  display flex
  align-items center
  justify-content center
  width 40px
  height 40px
  border none
  background none
  cursor pointer
  border-radius var(--radius-sm)
  color var(--color-text)

.mobile-menu-btn:hover
  background var(--color-bg-alt)

@media (min-width: 768px)
  .mobile-menu-btn
    display none

.mobile-nav
  display none
  position fixed
  top var(--header-height)
  left 0
  right 0
  bottom 0
  background var(--color-bg)
  z-index 99
  padding 20px

.mobile-nav.open
  display block

.mobile-nav a
  display block
  padding 14px 0
  color var(--color-text)
  font-size 1.1rem
  font-weight 500
  border-bottom 1px solid var(--color-border-light)

.mobile-nav a:hover
  color var(--color-primary)

.mobile-lang-list
  padding 10px 0
  display flex
  flex-wrap wrap
  gap 6px

.mobile-lang-list a
  display inline-flex
  align-items center
  gap 6px
  padding 6px 12px
  border 1px solid var(--color-border)
  border-radius var(--radius-sm)
  font-size 0.9rem
  border-bottom none
  width auto

.mobile-lang-list a:hover
  border-color var(--color-primary)
  background var(--color-primary-light)

/* ===== Hero ===== */
.hero
  background #ffffff
  color var(--color-text)
  padding 100px 0 120px
  position relative
  overflow hidden

.hero::before
  content ''
  position absolute
  top 0
  left 0
  right 0
  bottom 0
  background radial-gradient(ellipse at 50% 0%, rgba(37,99,235,0.03) 0%, transparent 70%)
  pointer-events none
  z-index 0

.hero .container
  position relative
  z-index 1
  display flex
  flex-direction column
  align-items center
  text-align center

.hero-logo
  max-height 100%
  height auto
  margin-bottom 5px
  margin-top -10px

.hero h1
  position absolute
  width 1px
  height 1px
  padding 0
  margin -1px
  overflow hidden
  clip rect(0, 0, 0, 0)
  white-space nowrap
  border 0

.hero-tagline
  font-size 1.15rem
  color var(--color-text-secondary)
  max-width 560px
  margin-bottom 8px
  line-height 1.7

.hero-version
  display inline-flex
  align-items center
  gap 8px
  padding 6px 14px
  background var(--color-border-light)
  border-radius 100px
  font-size 0.85rem
  color var(--color-text-secondary)
  margin-bottom 28px

.hero-version .dot
  width 7px
  height 7px
  border-radius 50%
  background var(--color-success)
  animation pulse 2s infinite

@keyframes pulse
  0%, 100%
    opacity 1
  50%
    opacity 0.5

.hero-cta
  display flex
  flex-direction column
  align-items center
  gap 12px

@media (min-width: 480px)
  .hero-cta
    flex-direction row

.hero-btn
  display inline-flex
  align-items center
  gap 8px
  padding 14px 28px
  border-radius var(--radius-md)
  font-size 1rem
  font-weight 600
  transition all 0.2s
  border none
  cursor pointer

.hero-btn-primary
  background var(--color-primary)
  color white
  box-shadow 0 4px 14px rgba(37,99,235,0.3)

.hero-btn-primary:hover
  background var(--color-primary-dark)
  color white
  transform translateY(-1px)
  box-shadow 0 6px 20px rgba(37,99,235,0.4)

.hero-btn-secondary
  background var(--color-bg)
  color var(--color-text)
  border 1px solid var(--color-border)

.hero-btn-secondary:hover
  background var(--color-border-light)
  color var(--color-text)

.hero-badges
  display flex
  flex-wrap wrap
  gap 8px
  justify-content center
  margin-top 24px

.hero-badges a
  display inline-block

.hero-badges img
  height 22px

@media (max-width: 479px)
  .hero
    padding 60px 0 70px
  .hero h1
    font-size 1.8rem
  .hero-tagline
    font-size 1rem

/* ===== Features ===== */
.features
  padding 80px 0
  background var(--color-bg)

.section-header
  text-align center
  margin-bottom 48px

.section-header h2
  font-size 2rem
  font-weight 700
  margin-bottom 12px
  letter-spacing -0.01em

.section-header p
  color var(--color-text-secondary)
  font-size 1.05rem
  max-width 520px
  margin 0 auto

.features-grid
  display grid
  grid-template-columns 1fr
  gap 16px

@media (min-width: 480px)
  .features-grid
    grid-template-columns repeat(2, 1fr)
    gap 20px

@media (min-width: 768px)
  .features-grid
    grid-template-columns repeat(3, 1fr)
    gap 24px

.feature-card
  padding 28px 24px
  border 1px solid var(--color-border)
  border-radius var(--radius-lg)
  background var(--color-bg)
  transition all 0.25s

.feature-card:hover
  border-color var(--color-primary)
  box-shadow var(--shadow-md)
  transform translateY(-2px)

.feature-icon
  width 44px
  height 44px
  display flex
  align-items center
  justify-content center
  border-radius var(--radius-md)
  background var(--color-primary-light)
  color var(--color-primary)
  font-size 1.3rem
  margin-bottom 16px

.feature-card h3
  font-size 1rem
  font-weight 600
  margin-bottom 8px

.feature-card p
  font-size 0.88rem
  color var(--color-text-secondary)
  line-height 1.6

/* ===== Download Section ===== */
.downloads
  padding 80px 0
  background var(--color-bg-alt)

.download-tabs-bar
  display flex
  gap 4px
  background var(--color-border-light)
  border-radius var(--radius-md)
  padding 4px
  margin-bottom 32px
  max-width 400px
  margin-left auto
  margin-right auto

.download-tab-btn
  flex 1
  padding 10px 16px
  border none
  background none
  border-radius var(--radius-sm)
  font-size 0.9rem
  font-weight 500
  color var(--color-text-secondary)
  cursor pointer
  transition all 0.2s

.download-tab-btn.active
  background var(--color-bg)
  color var(--color-text)
  box-shadow var(--shadow-sm)

.download-tab-btn:hover:not(.active)
  color var(--color-text)

.download-panel
  display none

.download-panel.active
  display block

.download-grid
  display grid
  grid-template-columns 1fr
  gap 12px

@media (min-width: 768px)
  .download-grid
    grid-template-columns repeat(2, 1fr)
    gap 16px

.download-card
  display flex
  align-items flex-start
  justify-content space-between
  padding 16px 20px
  background var(--color-bg)
  border 1px solid var(--color-border)
  border-radius var(--radius-md)
  transition all 0.2s
  flex-wrap wrap
  gap 12px

.download-card:hover
  border-color var(--color-primary)
  box-shadow var(--shadow-sm)

.download-card-top
  width 100%

.download-card-name
  font-weight 600
  font-size 0.95rem
  word-break break-all

.download-card-desc
  font-size 0.82rem
  color var(--color-text-secondary)
  margin-top 2px

.download-card-links
  display flex
  gap 6px
  flex-wrap wrap

.download-card-link
  padding 6px 12px
  border-radius var(--radius-sm)
  font-size 0.8rem
  font-weight 500
  border 1px solid var(--color-border)
  color var(--color-text-secondary)
  transition all 0.15s
  white-space nowrap

.download-card-link:hover
  border-color var(--color-primary)
  color var(--color-primary)

.download-card-link.primary
  background var(--color-primary)
  border-color var(--color-primary)
  color white

.download-card-link.primary:hover
  background var(--color-primary-dark)

.download-more
  text-align center
  margin-top 32px

.download-more a
  display inline-flex
  align-items center
  gap 6px
  padding 10px 20px
  border 1px solid var(--color-border)
  border-radius var(--radius-md)
  color var(--color-text-secondary)
  font-size 0.9rem
  font-weight 500
  transition all 0.2s

.download-more a:hover
  border-color var(--color-primary)
  color var(--color-primary)

@media (max-width: 479px)
  .download-card
    flex-direction column
  .download-card-links
    width 100%

.arch-bar
  display flex
  gap 4px
  flex-wrap wrap
  margin-bottom 16px

.arch-btn
  padding 6px 14px
  border 1px solid var(--color-border)
  background var(--color-bg)
  border-radius 100px
  font-size 0.8rem
  color var(--color-text-secondary)
  cursor pointer
  transition all 0.15s

.arch-btn.active
  background var(--color-text)
  border-color var(--color-text)
  color white

.arch-btn:hover:not(.active)
  border-color var(--color-primary)

.arch-panel
  display none

.arch-panel.active
  display block

/* ===== Links Section ===== */
.links-section
  padding 80px 0
  background var(--color-bg)

.links-grid
  display grid
  grid-template-columns 1fr
  gap 32px

@media (min-width: 768px)
  .links-grid
    grid-template-columns repeat(2, 1fr)
    gap 40px

@media (min-width: 1024px)
  .links-grid
    grid-template-columns repeat(3, 1fr)

.link-category h3
  font-size 1rem
  font-weight 600
  margin-bottom 16px
  padding-bottom 12px
  border-bottom 2px solid var(--color-primary)
  display inline-block

.link-list
  list-style none

.link-list li
  margin-bottom 4px

.link-list a
  display flex
  align-items center
  gap 8px
  padding 8px 12px
  border-radius var(--radius-sm)
  color var(--color-text-secondary)
  font-size 0.9rem
  transition all 0.15s

.link-list a:hover
  background var(--color-bg-alt)
  color var(--color-primary)

.link-list a::before
  content ''
  width 5px
  height 5px
  border-radius 50%
  background var(--color-border)
  flex-shrink 0
  transition background 0.15s

.link-list a:hover::before
  background var(--color-primary)

/* ===== Community ===== */
.community
  padding 60px 0
  background var(--color-bg-alt)
  text-align center

.community h2
  font-size 1.5rem
  margin-bottom 20px

.community-qr
  max-width 180px
  border-radius var(--radius-md)
  box-shadow var(--shadow-md)
  margin-bottom 12px

.community p
  color var(--color-text-secondary)
  font-size 0.9rem

/* ===== Changelog ===== */
.changelog
  padding 60px 0
  background var(--color-bg)

.changelog-card
  background var(--color-bg-alt)
  border-radius var(--radius-lg)
  padding 32px
  max-width 800px
  margin 0 auto

.changelog-header
  display flex
  align-items center
  gap 16px
  margin-bottom 20px
  flex-wrap wrap

.changelog-version-badge
  padding 4px 12px
  background var(--color-primary)
  color white
  border-radius 100px
  font-size 0.85rem
  font-weight 600

.changelog-date
  color var(--color-text-secondary)
  font-size 0.9rem

.changelog-body
  line-height 1.8
  font-size 0.92rem

.changelog-body p
  padding 4px 0

.changelog-body .separator
  border-top 1px solid var(--color-border)
  margin 12px 0

/* ===== Footer ===== */
.site-footer
  background #0f172a
  color rgba(255,255,255,0.6)
  padding 48px 0 24px

.footer-grid
  display grid
  grid-template-columns 1fr
  gap 32px
  margin-bottom 40px

@media (min-width: 480px)
  .footer-grid
    grid-template-columns repeat(2, 1fr)

@media (min-width: 768px)
  .footer-grid
    grid-template-columns 2fr repeat(3, 1fr)

.footer-brand
  max-width 280px

.footer-brand-name
  display flex
  align-items center
  gap 10px
  color white
  font-weight 700
  font-size 1.1rem
  margin-bottom 12px

.footer-brand-name img
  height 28px

.footer-brand p
  font-size 0.85rem
  line-height 1.6

.footer-col h4
  color white
  font-size 0.85rem
  font-weight 600
  text-transform uppercase
  letter-spacing 0.05em
  margin-bottom 16px

.footer-col ul
  list-style none

.footer-col li
  margin-bottom 8px

.footer-col a
  color rgba(255,255,255,0.5)
  font-size 0.88rem
  transition color 0.2s

.footer-col a:hover
  color white

.footer-bottom
  padding-top 24px
  border-top 1px solid rgba(255,255,255,0.1)
  display flex
  flex-direction column
  gap 12px
  align-items center

@media (min-width: 768px)
  .footer-bottom
    flex-direction row
    justify-content space-between

.footer-bottom p
  font-size 0.82rem

.footer-bottom-links
  display flex
  gap 16px

.footer-bottom-links a
  color rgba(255,255,255,0.4)
  font-size 0.82rem

.footer-bottom-links a:hover
  color white

/* ===== Demo ===== */
.demo-section
  padding 80px 0
  background var(--color-bg-alt)

.demo-wrapper
  max-width 960px
  margin 0 auto
  border-radius var(--radius-lg)
  overflow hidden
  box-shadow var(--shadow-xl)
  border 1px solid var(--color-border)

.demo-toolbar
  display flex
  align-items center
  gap 12px
  padding 12px 16px
  background #2d2d2d
  border-bottom 1px solid rgba(255,255,255,0.08)

.demo-dots
  display flex
  gap 7px

.demo-dots span
  width 12px
  height 12px
  border-radius 50%

.dot-red
  background #ff5f57

.dot-yellow
  background #febc2e

.dot-green
  background #28c840

.demo-address
  flex 1
  display flex
  align-items center
  gap 8px
  padding 6px 14px
  background rgba(255,255,255,0.08)
  border-radius 6px
  font-size 0.82rem
  color rgba(255,255,255,0.6)
  font-family var(--font-mono)

.demo-fullscreen
  padding 6px 12px
  border-radius var(--radius-sm)
  font-size 0.78rem
  color rgba(255,255,255,0.6)
  transition all 0.15s
  white-space nowrap

.demo-fullscreen:hover
  color white
  background rgba(255,255,255,0.1)

.demo-iframe
  display block
  width 100%
  height 500px
  border none
  background #1e1e1e

@media (min-width: 768px)
  .demo-iframe
    height 600px

@media (max-width: 767px)
  .demo-toolbar
    padding 10px 12px
  .demo-address
    font-size 0.75rem
    padding 4px 10px
  .demo-iframe
    height 400px

/* ===== Star History ===== */
.star-history
  padding 60px 0
  background var(--color-bg-alt)
  text-align center

.star-history img
  max-width 800px
  width 100%
  border-radius var(--radius-md)

/* ===== Hero Canvas Animation ===== */
#hero-anim
  position absolute
  top 0
  left 0
  width 100%
  height 100%
  z-index 0
  pointer-events none

.hero-canvas
  display block
  width 100%
  height 100%

#container
  position relative
  z-index 0

/* ===== Sponsors ===== */
.sponsors-section
  padding 60px 0
  background var(--color-bg)
  border-top 1px solid var(--color-border)

.sponsors-grid
  display flex
  flex-wrap wrap
  justify-content center
  align-items center
  gap 32px

.sponsor-badge-link
  display inline-block
  opacity 0.7
  transition opacity 0.2s

.sponsor-badge-link:hover
  opacity 1

.sponsor-badge
  height 48px
  width auto
  object-fit contain

.sponsor-badge-sm
  height 24px

.become-sponsor
  text-align center
  margin-top 40px
  padding-top 32px
  border-top 1px solid var(--color-border-light)

.become-sponsor p
  color var(--color-text-secondary)
  font-size 0.95rem
  margin-bottom 16px

.sponsor-contact-link
  display inline-flex
  align-items center
  gap 8px
  padding 10px 24px
  background var(--color-primary)
  color white
  border-radius var(--radius-md)
  font-size 0.9rem
  font-weight 500
  transition all 0.2s
  box-shadow 0 2px 8px rgba(37,99,235,0.2)

.sponsor-contact-link:hover
  background var(--color-primary-dark)
  color white
  transform translateY(-1px)
  box-shadow 0 4px 12px rgba(37,99,235,0.3)

/* ===== Deb Page ===== */
/* ===== Privacy Policy ===== */
.privacy-page
  padding 80px 0 100px
  background var(--color-bg)

.privacy-content
  max-width 800px
  margin 0 auto

.privacy-content h1
  font-size 2rem
  font-weight 700
  margin-bottom 8px

.privacy-content .last-updated
  color var(--color-text-secondary)
  font-size .9rem
  margin-bottom 40px

.privacy-content h2
  font-size 1.3rem
  font-weight 600
  margin-top 36px
  margin-bottom 16px
  padding-bottom 8px
  border-bottom 2px solid var(--color-primary)
  display inline-block

.privacy-content h3
  font-size 1.05rem
  font-weight 600
  margin-top 24px
  margin-bottom 10px

.privacy-content p
  margin-bottom 14px
  line-height 1.75
  color var(--color-text-secondary)
  font-size .95rem

.privacy-content ul
  margin-bottom 14px
  padding-left 24px

.privacy-content li
  margin-bottom 8px
  line-height 1.7
  color var(--color-text-secondary)
  font-size .95rem

.privacy-content a
  color var(--color-primary)

.privacy-content a:hover
  color var(--color-primary-dark)

.privacy-content table
  width 100%
  border-collapse collapse
  margin 16px 0 24px
  font-size .9rem

.privacy-content th,
.privacy-content td
  padding 12px 16px
  text-align left
  border 1px solid var(--color-border)

.privacy-content th
  background var(--color-bg-alt)
  font-weight 600
  color var(--color-text)

.privacy-content td
  color var(--color-text-secondary)

/* ===== Cookie Consent ===== */
#cookie-consent
  position fixed
  bottom 0
  left 0
  right 0
  z-index 9999
  background #fff
  border-top 1px solid var(--color-border)
  box-shadow 0 -2px 10px rgba(0, 0, 0, .06)
  padding 20px

.cookie-consent-inner
  max-width 1200px
  margin 0 auto
  display flex
  flex-wrap wrap
  align-items center
  justify-content space-between
  gap 16px

.cookie-consent-text
  flex 1
  min-width 280px
  font-size .9rem
  color var(--color-text-secondary)
  line-height 1.6
  margin 0

.cookie-consent-text a
  color var(--color-primary)
  text-decoration underline

.cookie-consent-actions
  display flex
  gap 10px
  flex-shrink 0

#cookie-reject
  padding 10px 20px
  border 1px solid var(--color-border)
  border-radius var(--radius-sm)
  background var(--color-bg)
  color var(--color-text-secondary)
  font-size .88rem
  font-weight 500
  cursor pointer
  transition all .15s

#cookie-reject:hover
  border-color var(--color-primary)
  color var(--color-primary)

#cookie-accept
  padding 10px 20px
  border none
  border-radius var(--radius-sm)
  background var(--color-primary)
  color #fff
  font-size .88rem
  font-weight 600
  cursor pointer
  transition all .15s

#cookie-accept:hover
  background var(--color-primary-dark)

@media (max-width: 600px)
  #cookie-consent
    padding 16px
  .cookie-consent-inner
    flex-direction column
    align-items stretch
  .cookie-consent-text
    min-width auto
  .cookie-consent-actions
    justify-content flex-end

/* ===== About Page ===== */
.about-page
  padding 80px 0 100px
  background var(--color-bg)

.about-content
  max-width 800px
  margin 0 auto

.about-content h1
  font-size 2rem
  font-weight 700
  margin-bottom 8px

.about-content .about-lead
  font-size 1.1rem
  color var(--color-text)
  margin-bottom 16px
  line-height 1.75

.about-content p
  margin-bottom 14px
  line-height 1.75
  color var(--color-text-secondary)
  font-size .95rem

.about-content h2
  font-size 1.3rem
  font-weight 600
  margin-top 40px
  margin-bottom 16px
  padding-bottom 8px
  border-bottom 2px solid var(--color-primary)
  display inline-block

.about-content h3
  font-size 1.05rem
  font-weight 600
  margin-top 24px
  margin-bottom 10px

.about-content ul
  margin-bottom 14px
  padding-left 24px

.about-content li
  margin-bottom 8px
  line-height 1.7
  color var(--color-text-secondary)
  font-size .95rem

.about-content li strong
  color var(--color-text)

.about-content a
  color var(--color-primary)

.about-content a:hover
  color var(--color-primary-dark)

.about-content code
  background var(--color-bg-alt)
  padding 2px 6px
  border-radius 4px
  font-size .85rem
  font-family var(--font-mono)
  border 1px solid var(--color-border-light)

.about-content pre
  background var(--color-bg-alt)
  border 1px solid var(--color-border)
  border-radius var(--radius-md)
  padding 20px 24px
  margin-bottom 20px
  overflow-x auto
  font-size .85rem
  line-height 1.6

.about-content pre code
  background none
  padding 0
  border none
  border-radius 0
  font-size inherit

.about-links-grid
  display grid
  grid-template-columns 1fr
  gap 16px
  margin-bottom 24px

@media (min-width: 600px)
  .about-links-grid
    grid-template-columns repeat(2, 1fr)

.about-link-card
  padding 24px
  border 1px solid var(--color-border)
  border-radius var(--radius-lg)
  transition all .2s

.about-link-card:hover
  border-color var(--color-primary)
  box-shadow var(--shadow-md)

.about-link-card h3
  font-size 1rem
  font-weight 600
  margin-bottom 8px
  margin-top 0

.about-link-card p
  font-size .85rem
  color var(--color-text-secondary)
  margin-bottom 12px

.about-content .about-link
  display inline-flex
  align-items center
  gap 4px
  padding 8px 16px
  background var(--color-primary)
  color white
  border-radius var(--radius-sm)
  font-size .85rem
  font-weight 500
  transition all .2s

.about-content .about-link:hover
  background var(--color-primary-dark)
  color white

/* ===== Home FAQ Section ===== */
.home-faq
  padding 60px 0
  background var(--color-bg-alt)

.home-faq-list
  max-width 700px
  margin 0 auto
  display flex
  flex-direction column
  gap 16px

.home-faq-item
  background var(--color-bg)
  border 1px solid var(--color-border)
  border-radius var(--radius-md)
  padding 20px 24px
  transition all .2s

.home-faq-item:hover
  border-color var(--color-primary)
  box-shadow var(--shadow-sm)

.home-faq-q
  font-weight 600
  font-size .95rem
  margin-bottom 6px
  color var(--color-text)

.home-faq-a
  font-size .88rem
  color var(--color-text-secondary)
  line-height 1.6

.home-faq-more
  text-align center
  margin-top 28px

.home-faq-link
  display inline-flex
  align-items center
  gap 6px
  padding 10px 24px
  background var(--color-primary)
  color white
  border-radius var(--radius-md)
  font-size .9rem
  font-weight 500
  transition all .2s

.home-faq-link:hover
  background var(--color-primary-dark)
  color white

/* ===== Home Author Section ===== */
.home-author
  padding 60px 0
  background var(--color-bg)

.author-inner
  max-width 700px
  margin 0 auto
  text-align center

.author-text h2
  font-size 1.2rem
  font-weight 700
  margin-bottom 10px

.author-text p
  font-size .88rem
  color var(--color-text-secondary)
  line-height 1.6
  margin-bottom 8px

.author-link
  display inline-flex
  align-items center
  gap 4px
  padding 8px 16px
  background var(--color-primary)
  color white
  border-radius var(--radius-sm)
  font-size .8rem
  font-weight 500
  margin-top 6px
  transition all .15s

.author-link:hover
  background var(--color-primary-dark)
  color white

/* ===== Contact Page ===== */
.contact-grid
  display grid
  grid-template-columns 1fr
  gap 20px
  margin 32px 0

@media (min-width: 600px)
  .contact-grid
    grid-template-columns repeat(3, 1fr)

.contact-card
  padding 28px 24px
  border 1px solid var(--color-border)
  border-radius var(--radius-lg)
  text-align center
  transition all .25s

.contact-card:hover
  border-color var(--color-primary)
  box-shadow var(--shadow-md)
  transform translateY(-2px)

.contact-icon
  font-size 2rem
  margin-bottom 12px

.contact-card h3
  font-size 1rem
  font-weight 600
  margin-bottom 8px

.contact-card p
  font-size .85rem
  color var(--color-text-secondary)
  margin-bottom 16px
  line-height 1.5

.privacy-content .contact-link
  display inline-flex
  align-items center
  gap 4px
  padding 8px 20px
  background var(--color-primary)
  color white
  border-radius var(--radius-sm)
  font-size .85rem
  font-weight 500
  transition all .2s

.privacy-content .contact-link:hover
  background var(--color-primary-dark)
  color white

.contact-wechat-section
  text-align center
  margin-top 40px
  padding-top 32px
  border-top 1px solid var(--color-border)

.contact-wechat-section h2
  font-size 1.2rem
  font-weight 700
  margin-bottom 8px
  border none
  display block
  margin-top 0

.contact-wechat-section p
  color var(--color-text-secondary)
  font-size .9rem
  margin-bottom 16px

.contact-qr
  max-width 200px
  border-radius var(--radius-md)
  box-shadow var(--shadow-md)
